{
  "buildCommand": "cd web-app/client && npm install && npm run build",
  "outputDirectory": "web-app/client/dist",
  "installCommand": "cd web-app/client && npm install",
  "framework": "vite",
  "routes": [
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
